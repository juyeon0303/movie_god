# Optional — PostgreSQL 사용 시 (없으면 data/snapshots/*.json)
DATABASE_URL=

# Optional — 없어도 OMDb demo key(trilogy)로 동작
OMDB_API_KEY=

# Optional — 포스터/줄거리 한글 메타데이터 보강
TMDB_API_KEY=

# RAG 무드 검색 + 임베딩 생성 (sync-tiers 시 명작 벡터화)
OPENAI_API_KEY=

# Optional — pgvector 직접 사용 시 true (기본은 JSON 파일 검색)
USE_PGVECTOR=false
